# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored and never committed.
#
# Used locally via `node --env-file=.env.local ...` (npm start / dev / migrate).
# On Vercel, set these same two variables under Project Settings -> Environment
# Variables instead (do NOT commit real keys).

# --- Supabase ---
# From https://supabase.com/dashboard -> your project -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Editing password ---
# Reads are public; recording/changing/undoing swipe decisions requires this code,
# typed once in the app's "Unlock to edit" box. Pick any secret phrase. If unset,
# editing is locked for everyone (safe default).
ADMIN_CODE=change-me-to-a-secret-phrase
